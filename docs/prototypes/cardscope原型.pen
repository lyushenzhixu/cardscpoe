            {
              "type": "text",
              "id": "mcndb",
              "name": "hs1t",
              "fill": "#374151",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "• 组合总价值：用户收藏里所有卡片的估价加总\n• 收藏张数：已加入收藏的卡数\n• 本月涨跌：相对上一周期的组合价值涨跌百分比（界面第三张卡文案为 THIS MONTH）\n• 最近扫描：首页最多展示 4 条，随首页刷新更新\n• 热门：首页最多展示 3 条；热门数据不可用时可改用本地按涨幅排序的备选列表",
              "fontFamily": "Inter",
              "fontSize": 11,
              "fontWeight": "normal"
            }
          ]
        },
