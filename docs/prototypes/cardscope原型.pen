            {
              "type": "text",
              "id": "FiKrU",
              "name": "hs3t",
              "fill": "#374151",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "• 主视觉或「立即扫描」：打开扫描流程（浮层/全屏）\n• 「最近扫描」右侧文案为 See All ›；「热门」右侧为 More ›\n• 点击列表任一行：进入对应卡片详情\n• 点击头像：切换到「我的」\n• 三张统计卡仅展示，不可点击\n• 下拉页面：刷新首页数据（加载态与失败提示需可感知）",
              "fontFamily": "Inter",
              "fontSize": 11,
              "fontWeight": "normal"
            }
          ]
        }
