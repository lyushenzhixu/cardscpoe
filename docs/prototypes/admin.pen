              "name": "s16bt",
              "fill": "$textSecondary",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "onboarding — Post-onboarding step 3\nfeatureLimit — Free scan/collection limit reached\nvalueUnlock — Pro feature gate (chart, AI grade, export)\nprofile — Manual upgrade from Profile tab\nEach source has different copy/CTAs in PaywallView",
              "lineHeight": 1.6,
              "fontFamily": "Inter",
