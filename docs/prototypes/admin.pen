              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "Players — CRUD on players table (name, team, position, sport)\nCards — CRUD on sports_cards table (12 columns shown)\nSeries — CRUD on series table (brand, setName, year, count)\nPrices — View/edit price_data (currentPrice, weekAgo, monthAgo)",
              "lineHeight": 1.6,
              "fontFamily": "Inter",
              "fontSize": 11,
              "fontWeight": "normal"
