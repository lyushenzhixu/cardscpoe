            },
            {
              "type": "rectangle",
              "id": "dJSTq",
              "name": "s13bd",
              "fill": "$borderLight",
              "width": "fill_container",
              "height": 1
            },
            {
              "type": "text",
              "id": "hzP9U",
              "name": "s13bt",
              "fill": "$textSecondary",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "playerName — String — from players.name join\nteam — String — players.team\nsport — SportType enum — NBA/MLB/NFL/Soccer\nbrand — String — card manufacturer\nyear — Int — release year\nsetName — String — card set name\nparallel — String? — optional parallel variant\nisRookie — Bool — rookie card flag\ncurrentPrice — Decimal — latest market price",
              "lineHeight": 1.6,
              "fontFamily": "Inter",
              "fontSize": 11,
              "fontWeight": "normal"
            }
          ]
        },
