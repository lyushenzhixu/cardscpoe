# CardScope 数据管道 - 环境变量示例
# 复制为 .env 并填入真实值

# Supabase（必须，用于写入数据库）
# 使用 Service Role Key 而非 Anon Key，以绕过 RLS 写入
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 数据源 API Keys（可选，未配置时使用种子数据）
# BallDontLie: https://app.balldontlie.io/ 免费注册
BALLDONTLIE_API_KEY=

# TheSportsDB: 使用 "1" 为免费演示 key，或申请 Patreon 获取更多额度
SPORTSDB_API_KEY=1

# PriceCharting: https://www.pricecharting.com/api 注册获取
# 注意：体育卡价格可能需 SportsCardsPro 付费订阅
PRICECHARTING_API_KEY=
